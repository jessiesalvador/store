# ─── Server ───────────────────────────────────────────────
NODE_ENV=development

# ─── MongoDB migration only ───────────────────────────────
# Only needed when running npm run migrate:firestore.
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/freshcart?retryWrites=true&w=majority

# ─── Sessions ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string
# Skip Firestore session touch writes until this many milliseconds have elapsed.
SESSION_TOUCH_INTERVAL_MS=300000

# ─── Rate limiting ────────────────────────────────────────
# Default uses Firestore counters so limits work across Firebase instances.
# Set to "memory" only for local development if Firestore is unavailable.
RATE_LIMIT_STORE=firestore

# ─── Firebase Storage ─────────────────────────────────────
# Optional. Defaults to PROJECT_ID.firebasestorage.app in deployed Firebase.
FIREBASE_STORAGE_BUCKET=jsstore-b6d73.firebasestorage.app

# ─── Email (Nodemailer) ───────────────────────────────────
# Using Gmail: enable App Passwords at myaccount.google.com/apppasswords
# Using Resend: SMTP host is smtp.resend.com, user is "resend", pass is your API key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="FreshCart <your@email.com>"

# ─── AI assistant (Anthropic Claude) ──────────────────────
# In Firebase, set ANTHROPIC_API_KEY in Secret Manager and deploy functions.
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Super admin (seeded once) ────────────────────────────
SUPER_ADMIN_EMAIL=ai.jessie@outlook.com
SUPER_ADMIN_PASSWORD=SuperAdmin#2026

# ─── Frontend URL (for email links / optional CORS allowlist) ─────────
CLIENT_URL=http://localhost:3000
