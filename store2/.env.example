# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/freshcart?retryWrites=true&w=majority

# ─── Sessions ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ─── Email (Nodemailer) ───────────────────────────────────
# Using Gmail: enable App Passwords at myaccount.google.com/apppasswords
# Using Resend: SMTP host is smtp.resend.com, user is "resend", pass is your API key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM="FreshCart <your@email.com>"

# ─── Super admin (seeded once) ────────────────────────────
SUPER_ADMIN_EMAIL=ai.jessie@outlook.com
SUPER_ADMIN_PASSWORD=SuperAdmin#2026

# ─── Frontend URL (for email links / optional CORS allowlist) ─────────
CLIENT_URL=http://localhost:3000
